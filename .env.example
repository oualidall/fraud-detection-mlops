# Kaggle API - obtenir via kaggle.com/settings (Create New Token)
# Le fichier kaggle.json contient ces 2 cles
KAGGLE_USERNAME=your-kaggle-username
KAGGLE_KEY=your-kaggle-key

# MLflow tracking
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=fraud-detection

# API
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO

# Model registry
MODEL_NAME=fraud_xgboost
MODEL_STAGE=Production
